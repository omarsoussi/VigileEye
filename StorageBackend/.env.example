# ─── Server ───
PORT=8004
LOG_LEVEL=info

# ─── JWT (shared secret with Auth service) ───
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256

# ─── Database (PostgreSQL via pgx) ───
DATABASE_URL=postgres://neondb_owner:npg_JlMpDFoa34rL@ep-restless-firefly-agyxskdr-pooler.c-2.eu-central-1.aws.neon.tech/CMstorage?sslmode=require

# ─── Camera Management Service ───
CAMERA_SERVICE_URL=http://localhost:8002

# ─── Streaming Service ───
STREAMING_SERVICE_URL=http://localhost:8003

# ─── MediaMTX ───
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_RTSP_URL=rtsp://localhost:8554

# ─── FFmpeg ───
FFMPEG_PATH=ffmpeg

# ─── Storage Mode: local | minio | azure ───
STORAGE_MODE=local

# ─── Local Storage ───
LOCAL_STORAGE_PATH=./data/recordings

# ─── MinIO (self-hosted S3) ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vigileeye-recordings
MINIO_USE_SSL=false

# ─── Azure Blob Storage ───
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=vigileeye-recordings

# ─── Recording Defaults ───
SEGMENT_DURATION_MINUTES=10
DEFAULT_RETENTION_DAYS=7
DEFAULT_QUOTA_GB=10
DEFAULT_BITRATE=2000000
DEFAULT_RESOLUTION=1280x720

# ─── Subscription / Billing Simulation ───
# FREE = local only, PRO = minio + azure
SUBSCRIPTION_TIER=FREE
