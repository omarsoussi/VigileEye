@startuml Auth_ResetPassword
skinparam backgroundColor #FAFAFA
skinparam sequenceArrowThickness 1.5
skinparam sequence {
    ArrowColor #37474F
    LifeLineBorderColor #B0BEC5
    LifeLineBackgroundColor #ECEFF1
    BoxBorderColor #78909C
    GroupBorderColor #7E57C2
    GroupBackgroundColor #EDE7F6
    GroupHeaderFontColor #311B92
    DividerBackgroundColor #E3F2FD
    DividerBorderColor #1565C0
    DividerFontColor #0D47A1
}
skinparam participant {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0D47A1
}
skinparam actor {
    BackgroundColor #FFF8E1
    BorderColor #F57F17
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title **Auth Service (port 8000) — Forgot Password & Reset Password**

actor "User" as U
participant "**Frontend**\n<<React / Ionic>>" as FE #FFF8E1
participant "**AuthRoute**\n<<API Layer>>" as AR #DBEAFE
participant "**AuthService**\n<<App Service>>" as AS #EDE7F6
participant "**ForgotPasswordUseCase**\n<<Use Case>>" as FUC #EDE7F6
participant "**ResetPasswordUseCase**\n<<Use Case>>" as RUC #EDE7F6
participant "**IUserRepository**\n<<Domain>>" as UR #F3E5F5
participant "**IOTPRepository**\n<<Domain>>" as OTPR #F3E5F5
participant "**DBUserRepository**\n<<Infrastructure>>" as DBU #E0F2F1
participant "**DBOTPRepository**\n<<Infrastructure>>" as DBOO #E0F2F1
participant "**OTPGenerator**\n<<Infra/Security>>" as OTPG #E0F2F1
participant "**PasswordHasher**\n<<Infra/Security>>" as PH #E0F2F1
participant "**EmailSender**\n<<Infra/External>>" as ES #FBE9E7
participant "**PostgreSQL**\n<<Database>>" as DB #F5F5F5

== ① Request Password Reset ==

U -> FE : Click "Forgot Password"
activate FE
FE --> U : Show email input form
U -> FE : Enter registered email
FE -> AR : POST /api/v1/auth/forgot-password\n{email}
activate AR
AR -> AS : forgot_password(email)
activate AS
AS -> FUC : execute(ForgotPasswordInput{email})
activate FUC

FUC -> UR : get_by_email(email)
activate UR
UR -> DBU : get_by_email(email)
activate DBU
DBU -> DB : SELECT * FROM users\nWHERE email = :email
activate DB
DB --> DBU : Row | None
deactivate DB
DBU --> UR : User | None
deactivate DBU
UR --> FUC : User | None
deactivate UR

note over FUC : Always return 200 OK\nregardless of user existence\n(prevents email enumeration)

alt [User exists AND is_verified = True]
    FUC -> OTPG : generate(length=6)
    activate OTPG
    OTPG --> FUC : "364819"
    deactivate OTPG

    FUC -> OTPR : invalidate_all_for_user(user_id,\nOTPPurpose.PASSWORD_RESET)
    activate OTPR
    OTPR -> DBOO : invalidate_all_for_user(...)
    activate DBOO
    DBOO -> DB : UPDATE otps SET is_used=TRUE\nWHERE user_id=:uid\nAND purpose='PASSWORD_RESET'
    activate DB
    DB --> DBOO : N rows updated
    deactivate DB
    DBOO --> OTPR : count
    deactivate DBOO
    OTPR --> FUC : count
    deactivate OTPR

    FUC -> OTPR : create(OTP{user_id, code,\npurpose=PASSWORD_RESET,\nexpires_at=NOW()+15min,\nis_used=False})
    activate OTPR
    OTPR -> DBOO : create(otp)
    activate DBOO
    DBOO -> DB : INSERT INTO otps\n(user_id, code, purpose,\nexpires_at, is_used=False)
    activate DB
    DB --> DBOO : OK
    deactivate DB
    DBOO --> OTPR : OTPModel
    deactivate DBOO
    OTPR --> FUC : OTP entity
    deactivate OTPR

    FUC -> ES : send_password_reset_email(email, otp_code)
    activate ES
    note right of ES : HTML email with 6-digit\nreset code valid 15 minutes
    ES --> FUC : Delivered
    deactivate ES
end

FUC --> AS : ForgotPasswordOutput(message_sent=True)
deactivate FUC
AS --> AR : ForgotPasswordOutput
deactivate AS
AR --> FE : 200 OK\n{message: "If the email exists,\na reset code was sent."}
deactivate AR
FE --> U : "Check your inbox\nfor the reset code"

== ② Submit New Password + Reset Code ==

U -> FE : Enter {email, otp_code, new_password}
FE -> AR : POST /api/v1/auth/reset-password\n{email, otp_code, new_password}
activate AR
AR -> AS : reset_password(email, otp_code, new_password)
activate AS
AS -> RUC : execute(ResetPasswordInput)
activate RUC

RUC -> UR : get_by_email(email)
activate UR
UR -> DBU : get_by_email(email)
activate DBU
DBU -> DB : SELECT * FROM users WHERE email=:email
activate DB
DB --> DBU : Row | None
deactivate DB
DBU --> UR : User | None
deactivate DBU
UR --> RUC : User | None
deactivate UR

alt [User not found]
    RUC --> AS : raise UserNotFoundError
    deactivate RUC
    AS --> AR : raise
    deactivate AS
    AR --> FE : 404 Not Found
    deactivate AR
    FE --> U : Show error
else [User found — validate OTP]
    RUC -> OTPR : get_valid_otp(user_id, code,\nOTPPurpose.PASSWORD_RESET)
    activate OTPR
    OTPR -> DBOO : get_valid_otp(...)
    activate DBOO
    DBOO -> DB : SELECT * FROM otps\nWHERE user_id=:uid AND code=:code\nAND purpose='PASSWORD_RESET'\nAND expires_at > NOW()\nAND is_used = False
    activate DB
    DB --> DBOO : Row | None
    deactivate DB
    DBOO --> OTPR : OTPModel | None
    deactivate DBOO
    OTPR --> RUC : OTP | None
    deactivate OTPR

    alt [OTP invalid or expired]
        RUC --> AS : raise OTPExpiredError
        deactivate RUC
        AS --> AR : raise
        deactivate AS
        AR --> FE : 400 Bad Request\n{detail: "Invalid or expired code"}
        deactivate AR
        FE --> U : Show error message
    else [OTP valid — update password]
        RUC -> PH : hash(new_password)
        activate PH
        PH --> RUC : hashed_password
        deactivate PH

        RUC -> RUC : user.update_password(hashed_password)\nuser.unlock_account()\n[failed_login_attempts=0, lockout_until=None]

        RUC -> UR : update(user)
        activate UR
        UR -> DBU : update(user)
        activate DBU
        DBU -> DB : UPDATE users\nSET password_hash=:hash,\nfailed_login_attempts=0,\nlockout_until=NULL\nWHERE id=:user_id
        activate DB
        DB --> DBU : OK
        deactivate DB
        DBU --> UR : UserModel
        deactivate DBU
        UR --> RUC : User
        deactivate UR

        RUC -> OTPR : invalidate_all_for_user(user_id,\nOTPPurpose.PASSWORD_RESET)
        activate OTPR
        OTPR -> DBOO : invalidate_all_for_user(...)
        activate DBOO
        DBOO -> DB : UPDATE otps SET is_used=TRUE\nWHERE user_id=:uid AND purpose='PASSWORD_RESET'
        activate DB
        DB --> DBOO : OK
        deactivate DB
        DBOO --> OTPR : OK
        deactivate DBOO
        OTPR --> RUC : OK
        deactivate OTPR

        RUC --> AS : ResetPasswordOutput(success=True)
        deactivate RUC
        AS --> AR : ResetPasswordOutput
        deactivate AS
        AR --> FE : 200 OK\n{message: "Password reset successful"}
        deactivate AR
        FE --> U : "Password updated!\nRedirecting to login..."
    end
end

deactivate FE

@enduml
