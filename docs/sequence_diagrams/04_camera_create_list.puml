@startuml Camera_Create_List
skinparam backgroundColor #FAFAFA
skinparam sequenceArrowThickness 1.5
skinparam sequence {
    ArrowColor #37474F
    LifeLineBorderColor #B0BEC5
    LifeLineBackgroundColor #ECEFF1
    BoxBorderColor #78909C
    GroupBorderColor #7E57C2
    GroupBackgroundColor #EDE7F6
    GroupHeaderFontColor #311B92
    DividerBackgroundColor #E3F2FD
    DividerBorderColor #1565C0
    DividerFontColor #0D47A1
}
skinparam participant {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0D47A1
}
skinparam actor {
    BackgroundColor #FFF8E1
    BorderColor #F57F17
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title **Camera Management Service (port 8002) — Create & List Cameras**

actor "User" as U
participant "**Frontend**\n<<React / Ionic>>" as FE #FFF8E1
participant "**CameraRoute**\n<<API Layer>>" as CR #DBEAFE
participant "**JWTHandler**\n<<Infra/Security>>" as JWT #E0F2F1
participant "**CameraService**\n<<App Service>>" as CS #EDE7F6
participant "**CreateCameraUseCase**\n<<Use Case>>" as CCUC #EDE7F6
participant "**ListUserCamerasUseCase**\n<<Use Case>>" as LCUC #EDE7F6
participant "**ICameraRepository**\n<<Domain>>" as CAMR #F3E5F5
participant "**DBCameraRepository**\n<<Infrastructure>>" as DBCAM #E0F2F1
participant "**PostgreSQL**\n<<Database>>" as DB #F5F5F5

== Service Lifecycle — Startup ==
note over CR, CS : FastAPI lifespan startup\n• Routers mounted on /api/v1/cameras\n• DB engine initialised\n• JWT secret loaded from settings

'─────────────────────────────────────
' JWT TOKEN VALIDATION — defined here,
' referenced by all subsequent diagrams
'─────────────────────────────────────
group JWT Token Validation [defined here — referenced in diagrams 05 to 10]
    FE -> CR : Authorization: Bearer <access_token>
    activate CR
    CR -> JWT : verify_token(token, token_type="access")
    activate JWT
    note right of JWT : Decode HS256 token\nVerify signature + expiry\nExtract payload: {user_id, email}
    alt [Token invalid or expired]
        JWT --> CR : raise JWTDecodeError
        deactivate JWT
        CR --> FE : 401 Unauthorized\n{detail: "Invalid or expired token"}
        deactivate CR
    else [Token valid]
        JWT --> CR : payload {user_id, email, exp}
        deactivate JWT
        note over CR : user_id injected into handler\nvia FastAPI Depends(get_current_user)
    end
end

== ① Create Camera ==

U -> FE : Fill camera form\n{name, stream_url, protocol, type,\nresolution, fps, encoding,\nlocation, description}
activate FE

FE -> CR : POST /api/v1/cameras\nAuthorization: Bearer <token>\n{camera payload}
activate CR

ref over FE, CR, JWT : JWT Token Validation

CR -> CS : create_camera(owner_user_id, camera_data)
activate CS
CS -> CCUC : execute(owner_user_id, name, stream_url,\nprotocol, resolution, fps, encoding,\ncamera_type, description,\nusername, password, location)
activate CCUC

CCUC -> CAMR : create(Camera{\nid=uuid4(),\nowner_user_id,\nname, stream_url,\nprotocol, resolution, fps,\nencoding, status=OFFLINE,\ncamera_type, is_active=True,\nlocation: CameraLocation{\n  building, floor, zone, room,\n  gps_lat, gps_long\n},\ncreated_at=NOW()})
activate CAMR
CAMR -> DBCAM : create(camera)
activate DBCAM
DBCAM -> DB : INSERT INTO cameras\n(id, owner_user_id, name,\nstream_url, protocol, status,\ncamera_type, is_active, building,\nfloor, zone, room, gps_lat,\ngps_long, fps, resolution,\nencoding, created_at)
activate DB
DB --> DBCAM : {id, created_at}
deactivate DB
DBCAM --> CAMR : CameraModel
deactivate DBCAM
CAMR --> CCUC : Camera entity
deactivate CAMR

CCUC --> CS : Camera entity
deactivate CCUC
CS --> CR : Camera entity
deactivate CS
CR --> FE : 201 Created\n{id, name, stream_url, status,\ncamera_type, is_active,\nlocation, created_at}
deactivate CR
FE --> U : Show new camera in dashboard

== ② List User Cameras ==

U -> FE : Open cameras dashboard
FE -> CR : GET /api/v1/cameras\nAuthorization: Bearer <token>
activate CR

ref over FE, CR, JWT : JWT Token Validation

CR -> CS : list_cameras(owner_user_id)
activate CS
CS -> LCUC : execute(user_id)
activate LCUC

LCUC -> CAMR : get_by_owner(owner_user_id)
activate CAMR
CAMR -> DBCAM : get_by_owner(owner_user_id)
activate DBCAM
DBCAM -> DB : SELECT * FROM cameras\nWHERE owner_user_id = :uid\nAND is_active = True\nORDER BY created_at DESC
activate DB
DB --> DBCAM : [Row, ...]
deactivate DB
DBCAM --> CAMR : [CameraModel, ...]
deactivate DBCAM
CAMR --> LCUC : [Camera, ...]
deactivate CAMR

LCUC --> CS : List[Camera]
deactivate LCUC
CS --> CR : List[Camera]
deactivate CS
CR --> FE : 200 OK\n[{id, name, status, camera_type,\nlast_heartbeat, location, ...}, ...]
deactivate CR
FE --> U : Render camera grid / list

deactivate FE

== Service Lifecycle — Shutdown ==
note over CR, CS : FastAPI lifespan shutdown\n• DB connection pool closed

@enduml
