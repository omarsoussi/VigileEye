@startuml Streaming_Stop_Active
skinparam backgroundColor #FAFAFA
skinparam sequenceArrowThickness 1.5
skinparam sequence {
    ArrowColor #37474F
    LifeLineBorderColor #B0BEC5
    LifeLineBackgroundColor #ECEFF1
    BoxBorderColor #78909C
    GroupBorderColor #7E57C2
    GroupBackgroundColor #EDE7F6
    GroupHeaderFontColor #311B92
    DividerBackgroundColor #E3F2FD
    DividerBorderColor #1565C0
    DividerFontColor #0D47A1
}
skinparam participant {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0D47A1
}
skinparam actor {
    BackgroundColor #FFF8E1
    BorderColor #F57F17
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title **Video Streaming Service (port 8003) — Stop Stream & List Active Streams**

actor "User" as U
participant "**Frontend**\n<<React / Ionic>>" as FE #FFF8E1
participant "**StreamRoute**\n<<API Layer>>" as SR #DBEAFE
participant "**JWTHandler**\n<<Infra/Security>>" as JWT #E0F2F1
participant "**StreamService**\n<<App Service>>" as SS #EDE7F6
participant "**StopStreamUseCase**\n<<Use Case>>" as STPUC #EDE7F6
participant "**ListActiveStreamsUseCase**\n<<Use Case>>" as LAUC #EDE7F6
participant "**GetStreamStatusUseCase**\n<<Use Case>>" as GSUC #EDE7F6
participant "**IStreamRepository**\n<<Domain>>" as STMR #F3E5F5
participant "**DBStreamRepository**\n<<Infrastructure>>" as DBST #E0F2F1
participant "**OpenCVCapture**\n<<Infra/OpenCV>>" as OCV #E8F5E9
participant "**WebSocketManager**\n<<Infra/WS>>" as WSM #E8F5E9
participant "**PostgreSQL**\n<<Database>>" as DB #F5F5F5

== ① Stop Stream ==

U -> FE : Click "Stop Stream" button
activate FE
FE -> SR : POST /api/v1/streams/stop\nAuthorization: Bearer <token>\n{camera_id}
activate SR

ref over FE, SR, JWT : JWT Token Validation

SR -> SS : stop_stream(camera_id)
activate SS
SS -> STPUC : execute(camera_id)
activate STPUC

STPUC -> STMR : get_active_session(camera_id)
activate STMR
STMR -> DBST : get_active_session(camera_id)
activate DBST
DBST -> DB : SELECT * FROM stream_sessions\nWHERE camera_id=:id\nAND status IN ('active','connecting',\n'reconnecting')
activate DB
DB --> DBST : Row | None
deactivate DB
DBST --> STMR : StreamSessionModel | None
deactivate DBST
STMR --> STPUC : StreamSession | None
deactivate STMR

alt [No active session found]
    STPUC --> SS : raise StreamNotFoundError
    deactivate STPUC
    SS --> SR : raise
    deactivate SS
    SR --> FE : 404 Not Found\n{detail: "No active stream for this camera"}
    deactivate SR
    FE --> U : Show info toast
else [Active session found]
    STPUC -> OCV : release(camera_id)
    activate OCV
    note right of OCV : cv2.VideoCapture.release()\nFrees camera / network resource
    OCV --> STPUC : OK
    deactivate OCV

    STPUC -> WSM : close_all_clients(camera_id)
    activate WSM
    note right of WSM : Sends WS CLOSE 1000\nto all connected clients\nfor this camera_id
    WSM --> FE : WS CLOSE 1000\n"Stream stopped by server"
    WSM --> STPUC : N clients disconnected
    deactivate WSM

    STPUC -> STPUC : session.stop()\n[status=STOPPED, stopped_at=NOW()]

    STPUC -> STMR : update(session{status=STOPPED,\nstopped_at=NOW()})
    activate STMR
    STMR -> DBST : update(session)
    activate DBST
    DBST -> DB : UPDATE stream_sessions\nSET status='stopped',\nstopped_at=NOW()\nWHERE id=:session_id
    activate DB
    DB --> DBST : OK
    deactivate DB
    DBST --> STMR : StreamSessionModel
    deactivate DBST
    STMR --> STPUC : StreamSession
    deactivate STMR

    STPUC --> SS : StreamSession (stopped)
    deactivate STPUC
    SS --> SR : StreamSession
    deactivate SS
    SR --> FE : 200 OK\n{session_id, status: "stopped",\nstopped_at}
    deactivate SR
    FE --> U : "Stream stopped"
end

== ② Get Stream Status ==

U -> FE : Check stream badge / indicator
FE -> SR : GET /api/v1/streams/status/{camera_id}\nAuthorization: Bearer <token>
activate SR

ref over FE, SR, JWT : JWT Token Validation

SR -> SS : get_stream_status(camera_id)
activate SS
SS -> GSUC : execute(camera_id)
activate GSUC

GSUC -> STMR : get_active_session(camera_id)
activate STMR
STMR -> DBST : get_active_session(camera_id)
activate DBST
DBST -> DB : SELECT * FROM stream_sessions\nWHERE camera_id=:id\nAND status NOT IN ('stopped','error')
activate DB
DB --> DBST : Row | None
deactivate DB
DBST --> STMR : StreamSessionModel | None
deactivate DBST
STMR --> GSUC : StreamSession | None
deactivate STMR

alt [No active session]
    GSUC --> SS : (is_streaming=False, session=None)
    deactivate GSUC
    SS --> SR : StatusResult{is_streaming: false}
    deactivate SS
    SR --> FE : 200 OK\n{is_streaming: false,\nsession: null}
    deactivate SR
    FE --> U : Show "Offline" badge
else [Active session exists]
    GSUC --> SS : (is_streaming=True, session)
    deactivate GSUC
    SS --> SR : StatusResult{is_streaming: true, session}
    deactivate SS
    SR --> FE : 200 OK\n{is_streaming: true,\nsession: {id, status, fps,\nstarted_at, last_frame_at}}
    deactivate SR
    FE --> U : Show "Live" badge + stream info
end

== ③ List All Active Streams (admin / dashboard view) ==

U -> FE : Open "Active Streams" panel
FE -> SR : GET /api/v1/streams/active\nAuthorization: Bearer <token>
activate SR

ref over FE, SR, JWT : JWT Token Validation

SR -> SS : list_active_streams()
activate SS
SS -> LAUC : execute()
activate LAUC

LAUC -> STMR : list_active()
activate STMR
STMR -> DBST : list_active()
activate DBST
DBST -> DB : SELECT * FROM stream_sessions\nWHERE status IN ('active',\n'connecting','reconnecting')\nORDER BY started_at DESC
activate DB
DB --> DBST : [Row, ...]
deactivate DB
DBST --> STMR : [StreamSessionModel, ...]
deactivate DBST
STMR --> LAUC : [StreamSession, ...]
deactivate STMR

LAUC --> SS : List[StreamSession]
deactivate LAUC
SS --> SR : List[StreamSession]
deactivate SS
SR --> FE : 200 OK\n[{camera_id, session_id,\nstatus, fps, started_at,\nlast_frame_at, reconnect_attempts}, ...]
deactivate SR
FE --> U : Render active streams list

deactivate FE

@enduml
