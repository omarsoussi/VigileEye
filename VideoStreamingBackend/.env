DATABASE_URL=postgresql+pg8000://neondb_owner:npg_JlMpDFoa34rL@ep-restless-firefly-agyxskdr-pooler.c-2.eu-central-1.aws.neon.tech/CMStreaming
PGSSLMODE=require
# Database Configuration (pg8000 driver)
# Note: '@' in password must be URL-encoded as %40
# Using STREAMING_DATABASE_URL if separate DB is required
STREAMING_DATABASE_URL=postgresql+pg8000://neondb_owner:npg_JlMpDFoa34rL@ep-restless-firefly-agyxskdr-pooler.c-2.eu-central-1.aws.neon.tech/CMStreaming

# JWT Configuration (must match Auth service)
# This will be loaded from ../Backend/.env via pydantic-settings
# JWT_SECRET_KEY should match the Auth service's secret
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256

# Streaming Configuration
DEFAULT_FPS=15
FRAME_QUALITY=85
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_DELAY_SECONDS=2

# Server Configuration
HOST=0.0.0.0
PORT=8003
