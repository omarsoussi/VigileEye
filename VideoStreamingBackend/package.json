{
  "name": "video-streaming-backend",
  "version": "1.0.0",
  "description": "VigileEye Video Streaming Service - WebRTC/RTSP gateway with clean architecture",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint src/",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "axios": "^1.6.5",
    "fluent-ffmpeg": "^2.1.2",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "mediasoup": "^3.13.16"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.5",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0"
  }
}
