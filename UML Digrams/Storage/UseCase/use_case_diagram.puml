@startuml
!theme plain
title Figure 5.1: Use Case Diagram – Storage Service

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #E8F4FD
    BorderColor #2196F3
}

left to right direction

actor "User" as User
actor "Camera\nManagement\nService" as CamSvc

rectangle "Storage Service" {
    ' ─── Recording ───
    usecase "Start Recording" as UC1
    usecase "Stop Recording" as UC2
    usecase "List Recordings" as UC3
    usecase "Download Recording" as UC4
    usecase "Stream Recording\n(Range Requests)" as UC5

    ' ─── Configuration ───
    usecase "Get Storage Config" as UC6
    usecase "Update Storage Config" as UC7
    usecase "Update Subscription Tier" as UC8

    ' ─── Metrics ───
    usecase "View Storage Metrics\n(Per Camera)" as UC9
    usecase "View Storage Metrics\n(Per User)" as UC10
    usecase "List Active Recordings" as UC11

    ' ─── Internal ───
    usecase "Fetch Camera Metadata" as UC12
    usecase "Enforce Retention Policy" as UC13
    usecase "Generate Download Token" as UC14
    usecase "Check Storage Quota" as UC15
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC11

UC1 ..> UC12 : <<include>>
UC1 ..> UC15 : <<include>>
UC4 ..> UC14 : <<include>>
UC1 ..> UC13 : <<extend>>
UC7 ..> UC8 : <<extend>>

CamSvc --> UC12

@enduml
