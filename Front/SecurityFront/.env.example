# React (CRA) environment variables
# Copy to `.env` to override defaults.

# Auth backend (Camera Monitoring System)
REACT_APP_API_URL=http://localhost:8000/api/v1

# Members Invitation backend
REACT_APP_MEMBERS_API_URL=http://localhost:8001/api/v1

# Cameras Management backend
REACT_APP_CAMERAS_API_URL=http://localhost:8002/api/v1

# Video Streaming backend (WebRTC)
REACT_APP_STREAMING_API_URL=ws://localhost:8003
REACT_APP_STREAMING_API_URL_HTTPS=wss://localhost:8003
