# ─── Server ───
PORT=8003
LOG_LEVEL=info

# ─── JWT (shared secret with Auth service) ───
JWT_SECRET=your-shared-jwt-secret-here

# ─── Camera Management Service ───
CAMERA_SERVICE_URL=http://localhost:8002

# ─── FFmpeg ───
FFMPEG_PATH=ffmpeg

# ─── WebRTC ICE Servers ───
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USERNAME=
TURN_CREDENTIAL=

# ─── Stream Defaults ───
DEFAULT_FPS=15
DEFAULT_WIDTH=1280
DEFAULT_HEIGHT=720
DEFAULT_CODEC=h264
DEFAULT_BITRATE=2000000

# ─── WebRTC UDP Port Range ───
WEBRTC_PORT_MIN=50000
WEBRTC_PORT_MAX=50100

# ─── Reconnect ───
MAX_RECONNECT_ATTEMPTS=3
RECONNECT_DELAY_MS=5000

# ─── MediaMTX (Media Server) ───
MEDIAMTX_ENABLED=true
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_WHEP_URL=http://localhost:8889
